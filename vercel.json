{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "node scripts/vercel-install.js || node ../scripts/vercel-install.js",
  "buildCommand": "node scripts/vercel-build.js || node ../scripts/vercel-build.js",
  "outputDirectory": "client/dist",
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "server/eng.traineddata"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}

{
  "name": "multimodal-document-analyzer",
  "version": "1.0.0",
  "description": "Multimodal Document Analyzer SaaS",
  "scripts": {
    "start": "node server/server.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node --watch server/server.js",
    "client": "npm run dev --prefix client",
    "build": "npm run build --prefix client",
    "postinstall": "node scripts/download-tessdata.js",
    "download-tessdata": "node scripts/download-tessdata.js"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "concurrently": "^8.2.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "mammoth": "^1.12.0",
    "mongoose": "^9.6.2",
    "multer": "^2.1.1",
    "pdf-parse": "1.1.1",
    "tesseract.js": "^7.0.0"
  }
}
